# API
NODE_ENV=production
PORT=3000
APP_URL=exp://192.168.1.10:8081

# docker-compose builds DATABASE_URL automatically from POSTGRES_* below.
# For running Prisma/Nest locally outside Docker, use:
# DATABASE_URL=postgresql://myuser:mypassword@localhost:5433/mydb

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Postgres
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydb

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
